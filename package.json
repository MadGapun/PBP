{
  "name": "pbp",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev:api:raw": "uv run --all-extras python start_dashboard.py",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:web:raw": "pnpm --dir frontend exec vite",
    "dev:web": "node scripts/dev-web.mjs",
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "build:web": "pnpm --dir frontend exec vite build",
    "preview:web": "pnpm --dir frontend exec vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
